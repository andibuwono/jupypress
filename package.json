{
    "name": "jupypress",
    "version": "0.1.0",
    "description": "A JupyterLab extension for converting notebooks into HTML slide presentations",
    "keywords": ["jupyter", "jupyterlab", "extension", "presentation", "slides"],
    "homepage": "https://github.com/andibuwono/jupypress",
    "repository": {"type": "git", "url": "https://github.com/andibuwono/jupypress.git"},
    "bugs": {"url": "https://github.com/andibuwono/jupypress/issues"},
    "license": "BSD-3-Clause",
    "author": "JupyPress Contributors",
    "main": "lib/index.js",
    "types": "lib/index.d.ts",
    "style": "style/index.css",
    "sideEffects": ["style/**/*"],
    "jupyterlab": {
        "extension": true,
        "outputDir": "jupypress/labextension",
        "discovery": {"server": {"managers": ["pip"], "base": {"name": "jupypress"}}}
    },
    "scripts": {
        "build": "jlpm run build:lib && jlpm run build:labextension",
        "build:lib": "rimraf tsconfig.tsbuildinfo && tsc --sourceMap",
        "build:labextension": "jlpm run build:lib && jupyter labextension build .",
        "build:prod": "jlpm run build:lib && jlpm run build:labextension --production",
        "watch": "tsc -w --sourceMap",
        "watch:labextension": "jupyter labextension watch .",
        "develop": "jlpm run build:lib && jupyter labextension develop --overwrite .",
        "test": "jest --coverage",
        "test:watch": "jest --watch",
        "lint": "eslint . --ext .ts,.tsx --ignore-path .gitignore",
        "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\""
    },
    "dependencies": {
        "@codemirror/commands": "^6.10.2",
        "@codemirror/lang-python": "^6.2.1",
        "@codemirror/language": "^6.12.1",
        "@codemirror/state": "^6.5.4",
        "@codemirror/view": "^6.39.14",
        "@jupyterlab/application": "^4.0.0",
        "@jupyterlab/apputils": "^4.0.0",
        "@jupyterlab/notebook": "^4.0.0",
        "@jupyterlab/outputarea": "^4.5.7",
        "@jupyterlab/rendermime": "^4.5.7",
        "@jupyterlab/settingregistry": "^4.0.0",
        "@jupyterlab/ui-components": "^4.0.0",
        "@lumino/commands": "^2.0.0",
        "@lumino/signaling": "^2.0.0",
        "@lumino/widgets": "^2.0.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0"
    },
    "devDependencies": {
        "@jupyterlab/builder": "^4.0.0",
        "@types/jest": "^29.5.0",
        "@types/node": "^20.0.0",
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "@typescript-eslint/eslint-plugin": "^6.0.0",
        "@typescript-eslint/parser": "^6.0.0",
        "eslint": "^8.50.0",
        "jest": "^29.5.0",
        "jest-environment-jsdom": "^29.5.0",
        "prettier": "^3.0.0",
        "rimraf": "^5.0.0",
        "ts-jest": "^29.1.0",
        "typescript": "^5.0.0"
    }
}
